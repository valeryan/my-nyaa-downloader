{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "skipLibCheck": true,
    "noEmit": false,
    "outDir": "./dist/editor/public",
    "rootDir": "./src/editor/client",
    "sourceMap": false
  },
  "include": ["./src/editor/client/**/*.ts"],
  "exclude": ["node_modules"]
}
